# RLS integration test environment. Use a dedicated non-production project only.
SUPABASE_TEST_URL=
SUPABASE_TEST_PUBLISHABLE_KEY=

# Recommended for CI: dedicated accounts authenticate at runtime.
SUPABASE_TEST_USER_A_EMAIL=
SUPABASE_TEST_USER_A_PASSWORD=
SUPABASE_TEST_USER_B_EMAIL=
SUPABASE_TEST_USER_B_PASSWORD=
SUPABASE_TEST_ADMIN_EMAIL=
SUPABASE_TEST_ADMIN_PASSWORD=
SUPABASE_TEST_INSTITUTION_EMAIL=
SUPABASE_TEST_INSTITUTION_PASSWORD=

# Optional local overrides for already-authenticated sessions.
SUPABASE_TEST_USER_A_TOKEN=
SUPABASE_TEST_USER_B_TOKEN=
SUPABASE_TEST_USER_A_ID=
SUPABASE_TEST_USER_B_ID=
SUPABASE_TEST_ADMIN_TOKEN=
SUPABASE_TEST_INSTITUTION_TOKEN=
