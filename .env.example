# SA Learn — Environment Template
# Copy to `.env` for local development. Never commit real values.
# Deployed environments MUST source these from Lovable Cloud / deployment secrets.

# --- Lovable Cloud (Supabase) — publishable client keys ---
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side mirrors (used by server functions / SSR)
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Server-only administration key for controlled seed/migration scripts.
# Never expose this through VITE_ variables or browser code.
# SUPABASE_SERVICE_ROLE_KEY=

# --- /prod-readiness gate (server-only) ---
# SITE_PASSWORD=
# SESSION_SECRET=

# --- Partner opportunities intake API (Codex) ---
# SA_LEARN_PARTNER_API_KEY=
